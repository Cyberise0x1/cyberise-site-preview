modules = ["nodej-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
RESEND_API_KEY = "YOUR_RESEND_API_KEY"
CLERK_SECRET_KEY = "YOUR_CLERK_SECRET_KEY"
DIRECT_URL = "YOUR_DATABASE_URL"
CLERK_WEBHOOK_SECRET = "YOUR_CLERK_WEBHOOK_SECRET"
ENCRYPTION_SECRET = "YOUR_ENCRYPTION_SECRET"
JWT_SECRET = "YOUR_JWT_SECRET"
VERCEL_TOKEN = "YOUR_VERCEL_TOKEN"
RESEND_SENDER_ADDRESS = "YOUR_SENDER_ADDRESS"
CONTACT_RECIPIENT_EMAIL = "YOUR_CONTACT_EMAIL"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 4747
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 22231
externalPort = 80
