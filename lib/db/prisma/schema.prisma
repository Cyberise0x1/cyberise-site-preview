generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  ACTIVE
  TERMINATED
  FAILED
}

model User {
  id        String   @id
  email     String   @unique
  role      UserRole @default(USER)
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  banned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders          Order[]
  emailLogs       EmailLog[]
  auditLogs       AuditLog[]       @relation("ActorAuditLogs")
  promoCodeUsages PromoCodeUsage[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Order {
  id                   String      @id @default(uuid())
  userId               String
  plan                 String
  region               String
  image                String
  linodeInstanceId     Int?
  ip                   String?
  rdpUsername          String?
  rdpPasswordEncrypted String?
  status               OrderStatus @default(PENDING)
  amount               Decimal     @db.Decimal(10, 2)
  durationDays         Int         @default(30)
  createdAt            DateTime    @default(now())
  expiresAt            DateTime?
  terminatedAt         DateTime?
  terminationReason    String?
  metadata             Json?

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cryptoPayments CryptoPayment[]

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("orders")
}

model CryptoPayment {
  id            String    @id @default(uuid())
  orderId       String
  paymentId     String    @unique
  payAddress    String
  payCurrency   String
  cryptoAmount  Decimal   @db.Decimal(18, 8)
  fiatAmount    Decimal   @db.Decimal(10, 2)
  fiatCurrency  String    @default("usd")
  paymentStatus String
  actuallyPaid  Decimal?  @db.Decimal(18, 8)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?
  ipnReceivedAt DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([orderId])
  @@index([paymentStatus])
  @@map("crypto_payments")
}

model MarketSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("market_settings")
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  subject   String
  status    String
  error     String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("email_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Decimal   @db.Decimal(5, 2)   // e.g., 10.00 = 10% off
  maxUses         Int?                            // null = unlimited
  usedCount       Int       @default(0)
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  usages PromoCodeUsage[]

  @@index([code])
  @@map("promo_codes")
}

model PromoCodeUsage {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  orderId     String?
  usedAt      DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([promoCodeId, userId])  // One use per user per code
  @@index([promoCodeId])
  @@index([userId])
  @@map("promo_code_usages")
}


