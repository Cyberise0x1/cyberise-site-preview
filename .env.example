# ============================================
# CORE ENVIRONMENT VARIABLES (Required)
# ============================================

# Database connection string (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database"

# Direct database connection URL (for migrations)
DIRECT_URL="postgresql://user:password@host:5432/database"

# JWT signing secret (minimum 32 characters)
JWT_SECRET="your-jwt-secret-min-32-characters-long"

# Data encryption secret (minimum 32 characters)
ENCRYPTION_SECRET="your-encryption-secret-min-32-characters"

# Environment mode: development | production | test
NODE_ENV="development"

# Secret for cron job authentication (REQUIRED in production).
# The cron endpoints terminate instances and delete servers in bulk; if
# this is unset the endpoints fail closed and reject every request.
CRON_SECRET="your-cron-secret"

# ============================================
# REDIS (Required)
# ============================================

# Redis connection URL
REDIS_URL="redis://default:password@host:6379"

# Redis authentication token
REDIS_TOKEN="your-redis-token"

# ============================================
# CLERK AUTHENTICATION (Required)
# ============================================

# Clerk backend API secret key
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook signature verification secret
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk frontend publishable key (client-side)
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."

# ============================================
# LINODE INTEGRATION (Required)
# ============================================

# Linode API authentication token
LINODE_API_TOKEN="your-linode-api-token"

# Linode API endpoint (default: https://api.linode.com/v4)
LINODE_API_URL="https://api.linode.com/v4"

# ============================================
# RESEND EMAIL SERVICE (Required)
# ============================================

# Resend email API key
RESEND_API_KEY="re_..."

# Email sender address (must be valid email)
RESEND_SENDER_ADDRESS="noreply@yourdomain.com"

# Contact form recipient email
CONTACT_RECIPIENT_EMAIL="contact@yourdomain.com"

# ============================================
# NOWPAYMENTS INTEGRATION (Required)
# ============================================

# NOWPayments API key
NOWPAYMENTS_API_KEY="your-nowpayments-api-key"

# NOWPayments IPN callback secret
NOWPAYMENTS_IPN_SECRET="your-nowpayments-ipn-secret"

# NOWPayments API endpoint (default: https://api.nowpayments.io)
NOWPAYMENTS_API_URL="https://api.nowpayments.io"

# ============================================
# RDP MONSTER INTEGRATION (Optional)
# ============================================

# RDP Monster API key (optional)
RDP_MONSTER_API_KEY="your-rdp-monster-api-key"

# RDP Monster account email (optional)
RDP_MONSTER_EMAIL="your-email@example.com"

# RDP Monster API endpoint (default: https://manager.rdp.monster/api.php)
RDP_MONSTER_API_URL="https://manager.rdp.monster/api.php"

# ============================================
# CLIENT-SIDE VARIABLES
# ============================================

# API base URL for frontend
VITE_API_URL="http://localhost:8080"
