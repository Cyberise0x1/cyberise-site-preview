# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# Redis (Upstash)
REDIS_URL="redis://default:token@host:port"
REDIS_TOKEN="your_upstash_token"

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_..."
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# JWT (for additional token signing if needed)
JWT_SECRET="your-jwt-secret-min-32-characters"

# Cron (for Vercel cron job authentication)
CRON_SECRET="your-cron-secret-min-32-chars"

# Linode API
LINODE_API_TOKEN="your-linode-api-token"
LINODE_API_URL="https://api.linode.com/v4"

# Email (Resend)
RESEND_API_KEY="re_..."
RESEND_SENDER_ADDRESS="noreply@yourdomain.com"
CONTACT_RECIPIENT_EMAIL="admin@yourdomain.com"

# Encryption (for RDP passwords)
ENCRYPTION_SECRET="your-encryption-secret-min-32-chars"

# Deployment
VERCEL_URL="http://localhost:3000"
NODE_ENV="development"
